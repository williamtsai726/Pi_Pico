.program parallel_tx
.side_set 1

.wrap_target
    out pins, 16    side 0 ; Drive 16 bits to pins while clock is Low
    nop             side 1 ; Clock High: DAC latches data.
.wrap

.program parallel_rx
.side_set 1

.wrap_target
    nop             side 0 ; Clock Low: ADC prepares next data
    in pins, 16     side 1 ; Sample 16 bits while clock is High
.wrap